# Generated by Ansible - Traefik Helm values
# Compatible with Traefik Helm chart v39+

ports:
  web:
    port: {{ traefik_web_port }}
    exposedPort: {{ traefik_web_port }}
{% if traefik_redirect_http_to_https %}
    # Traefik Helm chart v39+ redirect syntax
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
          permanent: true
{% endif %}
  websecure:
    port: {{ traefik_websecure_port }}
    exposedPort: {{ traefik_websecure_port }}
    tls:
      enabled: true

service:
  type: {{ traefik_service_type }}

deployment:
  replicas: {{ traefik_replicas }}

resources:
  requests:
    cpu: "{{ traefik_cpu_request }}"
    memory: "{{ traefik_memory_request }}"
  limits:
    cpu: "{{ traefik_cpu_limit }}"
    memory: "{{ traefik_memory_limit }}"

logs:
  general:
    level: {{ traefik_log_level }}
  access:
    enabled: {{ traefik_access_log_enabled | lower }}
